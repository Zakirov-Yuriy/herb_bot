const solitaire = (function(win, doc) {
    // private =======================================================
    // ===============================================================

    // config -----------------------------
    // ------------------------------------
    const TEMPLATE_PATH = "/js/templates/";
    const ARTIKUL_IMAGE_PATH = "/images/data/artifacts/";

    const STATE_HELP = "help";
    const STATE_FULL = "full";
    const STATE_OPEN = "open";
    const STATE_CLOSE = "close";
    const STATE_UNLOCKED = "unlocked";
    const STATE_DISABLED = "disabled";
    const STATE_CLOSE_MAIN_REWARD = "closeMainReward";

    const CLAIM_REWARD = "reward";
    const CLAIM_CARD = "card";

    const is_extopen = !!navigator.userAgent.match(/extopen\/1/);

    var elements = {};
    var awardsMap = {};

    var template_cardStackButton = null;
    var template_bodyColumn = null;
    var template_stackCard = null;
    var template_flipCard = null;
    var template_bankIframeContainer = null;
    var template_error = null;

    var solitaire_id = null;
    var solitaire_data = null;
    var update_data = null;

    var rowId = -1;
    var mainRowId = -1;
    var expireTimer = 0;
    var modalCloseTimer = 0;
    var waitForUpdate = false;
    var waitForConfirm = false;
    var mainAwardGiven = false;
    var lastFlipCard = null;
    var confirmType = null;
    var sortedColumns = [];

    var cardPlurals = ["карта", "карты", "карт"];
    var countPlurals = ["раз", "раза", "раз"];

    // methods ----------------------------
    // ------------------------------------
    function setupFlipCards(cnt, selected_rows) {
        var nodes = [];
        var num = -1;

        elements["cardFlipper"].innerHTML = "";

        for (var i = 0; i < cnt; i++) {
            var node = template_flipCard.cloneNode(true);
            node.style.transitionDelay = 500 + (100 * i) + "ms";

            // Ждём пока последняя карточка проанимируется
            if (i === cnt - 1) {
                lastFlipCard = node;

                node.addEventListener("transitionend", onCardFlipTransitionEnd);
                node.addEventListener("webkitTransitionEnd", onCardFlipTransitionEnd);
            }

            elements["cardFlipper"].appendChild(node);
            nodes.push(node);
        }

        for (var key in selected_rows) {
            var value = selected_rows[key];
            var stackRow = elements["body"].querySelector("[data-id='" + key + "']");
            var cardImage = "";
            
            // Не знаю почему тут элемента может не быть
            // но один раз всплыла ошибка
            if (stackRow) {
                cardImage = stackRow.dataset.cardImage;
            }

            for (var v = 0; v < value; v++) {
                nodes[++num].querySelector(".card-flip-image").style.backgroundImage = "url('" + cardImage + "')";
                nodes[num].querySelector(".card-flip-back").style.backgroundImage = "url('" + solitaire_data.solitaire.backcard_image + "')";
            }
        }
    }

    function setupColumn(data, isLastColumn) {
        var awards = data.object_awards;
        var node = template_bodyColumn.cloneNode(true);
        var rewardButton = node.querySelector("[data-action='reward']");
        var cardButton = node.querySelector("[data-action='card']");

        var isOneAward = solitaire_data.solitaire.last_row_one_award;

        node.dataset.id = data.id;
        node.dataset.stackType = data.cnt;
        node.dataset.cardImage = data.card_image;
        node.dataset.lastColumn = isLastColumn.toString();

        if (awards.length > 0) {
            var mainArtikul = solitaire_data.artikul_hash[awards[0].artikul_id];
            var columnReward = node.querySelector(".column-reward");

            columnReward.setAttribute("div_id", "AA_" + awards[0].artikul_id);
            win.useAjaxArtifactAlt(columnReward);

            columnReward.addEventListener("click", onColumnRewardClick.bind(null, awards));

            node.querySelector(".column-reward-image").setAttribute("src", ARTIKUL_IMAGE_PATH + mainArtikul.picture);

            rewardButton.addEventListener("click", onClaimReward.bind(null, data.id));
            rewardButton.addEventListener("mouseover", onClaimOver.bind(null, CLAIM_REWARD));
            rewardButton.addEventListener("mouseout", hideTooltip);
        } else {
            // Если у колонки не заданы награды
            // скрываем икноку наград и кнопку получения награды
            node.querySelector(".column-reward").style.visibility = "hidden";
            rewardButton.style.visibility = "hidden";
        }
        
        node.querySelector(".column-reward-image").style.backgroundImage = "url('" + data.card_image + "')";
        node.querySelector(".column-text").innerText = "собрано " + pluralize(0, countPlurals);

        cardButton.addEventListener("click", onClaimCard.bind(null, data.id));
        cardButton.addEventListener("mouseover", onClaimOver.bind(null, CLAIM_CARD));
        cardButton.addEventListener("mouseout", hideTooltip);

        // Это последняя колонка
        if (isLastColumn) {
            if (Boolean(solitaire_data.solitaire.last_row_final)) {
                // Финальная награда (сундук) только одна и она уже выдана
                if (isOneAward && mainAwardGiven) {
                    cardButton.style.display = "none";
                }
            } else {
                // Последняя колонка и есть финальная награда (игра без сундука),
                // т.е. дальше некуда карту перекидывать
                cardButton.style.display = "none";
            }
        }

        return node;
    }

    function setupColumns() {
        var columns = solitaire_data.solitaire.rows;

        sortedColumns = columns.sort(function(a, b) {
            return parseInt(a.sort) - parseInt(b.sort);
        });

        var lastColumn = sortedColumns[sortedColumns.length - 1];
        mainAwardGiven = lastColumn.object_awards_give;

        // Заполняем колонки, кроме последней
        for (var i = 0; i < columns.length - 1; i++) {
            elements["body"].appendChild(
                setupColumn(columns[i], i === (columns.length - 2))
            );

            awardsMap[columns[i].id] = columns[i].object_awards;
        }

        if (Boolean(solitaire_data.solitaire.last_row_final)) {
            // Если последняя колонка - это сундук
            // то настраеваем его внешний вид
            setupMainReward(lastColumn);
        } else {
            // Иначе просто вставляем последнюю колонку как обычно
            elements["body"].appendChild(
                setupColumn(lastColumn, true)
            );

            // А сундук прячется
            elements["mainReward"].dataset.id = null;
            elements["mainReward"].dataset.rewardType = 0;
        }

        awardsMap[lastColumn.id] = lastColumn.object_awards;
    }

    function setupMainReward(data) {
        var awards = data.object_awards;
        var artikul = solitaire_data.artikul_hash[awards[0].artikul_id];

        var isOneAward = solitaire_data.solitaire.last_row_one_award;
        mainAwardGiven = data.object_awards_give;

        elements["mainReward"].dataset.id = data.id;
        elements["mainReward"].dataset.rewardType = data.cnt;

        if (isOneAward && mainAwardGiven) {
            // Главную награду можно получить лишь раз
            // и она уже выдавалась
            elements["mainReward"].dataset.rewardType = 0;
        } else {
            elements["mainReward"].setAttribute("div_id", "AA_" + awards[0].artikul_id);
            win.useAjaxArtifactAlt(elements["mainReward"]);

            elements["mainRewardConfirmPopupImage"].setAttribute("src", ARTIKUL_IMAGE_PATH + artikul.picture);
            elements["mainRewardConfirmPopupImage"].parentNode.setAttribute("div_id", "AA_" + awards[0].artikul_id);
            win.useAjaxArtifactAlt(elements["mainRewardConfirmPopupImage"].parentNode);

            elements["mainRewardChestChains"].addEventListener("transitionend", onChestChainsTransitionEnd.bind(null, data));
            elements["mainRewardConfirmPopupButton"].addEventListener("click", onMainRewardPopupClose);
        }
    }

    function setupCardOpenButtons() {
        var buttons = solitaire_data.solitaire.open_count_cards;

        for (var i = 0; i < buttons.length; i++) {
            var cnt = buttons[i];
            var node = template_cardStackButton.cloneNode(true);

            if (solitaire_data.user_card_cnt < cnt) {
                node.dataset.state = STATE_DISABLED;
            }

            node.dataset.cnt = cnt;
            node.querySelector(".rounded-button-text").innerText = cnt;
            node.addEventListener("click", onOpenCardButtonClick);

            elements["cardStackButtons"].appendChild(node);
        }
    }

    function setupCardsBack() {
        var cardCoverArr = elements["cardStack"].querySelectorAll(".card-cover");

        for (var i = 0; i < cardCoverArr.length; i++) {
            cardCoverArr[i].style.backgroundImage = "url('" + solitaire_data.solitaire.backcard_image + "')";
        }
    }

    function setupExpireTime() {
        var dateEnd = solitaire_data.solitaire.date_end * 1000;
        var dateNow = Date.now();
        var timeLeft = dateEnd - dateNow;

        if (timeLeft > 0) {
            var days = Math.floor(timeLeft / (1000 * 60 * 60 * 24));
            var hours = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            var minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
            var seconds = Math.floor((timeLeft % (1000 * 60)) / 1000);
            
            var text = "";

            if (days > 0) {
                if (days < 100) {
                    text += ("00" + days).slice(-2) + "д ";
                } else {
                    text += days + "д ";
                }
            }

            if (hours > 0) {
                text += ("00" + hours).slice(-2) + "ч ";
            } else {
                text += "00ч ";
            }

            if (minutes > 0) {
                text += ("00" + minutes).slice(-2) + "м ";
            } else {
                text += "00м ";
            }

            if (days <= 0) {
                text += ("00" + seconds).slice(-2) + "с ";
            }

            elements["timerValue"].innerText = text;
        }
    }

    function setupTimer() {
        clearInterval(expireTimer);

        expireTimer = setInterval(setupExpireTime, 1000);
    }

    function updateCardsHeader(num) {
        num = isNull(num) ? solitaire_data.user_card_cnt : num;
        elements["cardsHeader"].innerText = pluralize(num, cardPlurals);
    }

    function updateCardOpenButtons(num) {
        num = isNull(num) ? solitaire_data.user_card_cnt : num;
        var buttons = elements["cardStackButtons"].querySelectorAll(".rounded-button");

        for (var i = 0; i < buttons.length; i++) {
            var button = buttons[i];
            var state = null;
            
            // Если на кнопке число больше чем карт у юзера
            // дизейблим кнопку
            if (parseInt(button.dataset.cnt) > num) {
                state = STATE_DISABLED;
            }

            button.dataset.state = state;
        }
    }

    function updateCardStacks(data) {
        for (var key in data) {
            var value = data[key];
            var cardStack = elements["body"].querySelector("[data-id='" + key + "']");

            if (cardStack) {
                var cardsParent = cardStack.querySelector(".column-stack-cards");
                var cardButton = cardStack.querySelector("[data-action='card']");
                var stackType = parseInt(cardStack.dataset.stackType);
                var stackCnt = Math.floor(value / stackType); // Сколько раз собрали стопку полностью
                var cardsCnt = Math.min(value, stackType); // Сколько сейчас карт в стопке

                var isOneAward = solitaire_data.solitaire.last_row_one_award;
                var hasChest = Boolean(solitaire_data.solitaire.last_row_final);

                cardStack.dataset.state = value >= stackType ? STATE_FULL : null;
                cardsParent.innerHTML = "";

                for (var i = 0; i < cardsCnt; i++) {
                    var node = template_stackCard.cloneNode(true);
                    node.dataset.cardNum = i + 1; // Индекс начинается с 1
                    node.querySelector(".stack-card-image").style.backgroundImage = "url('" + cardStack.dataset.cardImage + "')";

                    cardsParent.appendChild(node);
                }

                cardStack.querySelector(".stack-full-image").style.backgroundImage = "url('" + cardStack.dataset.cardImage + "')";
                cardStack.querySelector(".column-text").innerText = "собрано " + pluralize(stackCnt, countPlurals);

                // Если это последняя колонка...
                if (cardStack.dataset.lastColumn === "true") {
                    if (hasChest) {
                        // и игра с сундуком...
                        if (isOneAward && mainAwardGiven) {
                            // но награда только одна и она уже выдана, то карту больше некуда передавать
                            cardButton.style.display = "none";
                        }
                    } else {
                        // и игра без сундука, то карту больше некуда передавать
                        cardButton.style.display = "none";
                    }
                }
            }
        }
    }

    function closeMainReward() {
        var chest = elements["mainReward"].querySelector(".chest");
        var chestLocks = elements["mainReward"].querySelectorAll(".chest-lock");
        var chestChain = elements["mainRewardChestChains"];

        var isOneAward = solitaire_data.solitaire.last_row_one_award;

        chest.dataset.state = "";
        chestChain.dataset.state = "";

        for (var i = 0; i < chestLocks.length; i++) {
            chestLocks[i].dataset.state = "";
        }

        // Награда была одна и показывать сундук нет больше смысла
        if (isOneAward && mainAwardGiven) {
            elements["mainReward"].dataset.rewardType = 0;
        }
    }

    function updateMainReward(data) {
        // Если нет большой финальной награды,
        // то тут нечего делать
        if (!Boolean(solitaire_data.solitaire.last_row_final)) {
            return;
        }

        for (var key in data) {
            if (parseInt(elements["mainReward"].dataset.id) === parseInt(key)) {
                var value = parseInt(data[key]);
                var rewardType = parseInt(elements["mainReward"].dataset.rewardType);

                var chest = elements["mainReward"].querySelector(".chest");
                var chestLocks = elements["mainReward"].querySelectorAll(".chest-lock");

                var isOneAward = solitaire_data.solitaire.last_row_one_award;

                value = Math.min(value, rewardType);

                closeMainReward();

                if (!isOneAward || !mainAwardGiven) {
                    for (var j = 0; j < value; j++) {
                        if (chestLocks[j]) {
                            chestLocks[j].dataset.state = STATE_UNLOCKED;
                        }
                    }

                    if (value === rewardType) {
                        elements["mainRewardChestChains"].dataset.state = STATE_UNLOCKED;
                        chest.dataset.state = STATE_UNLOCKED;
                    }
                }

                break;
            }
        }
    }

    function updateState(data) {
        if (!data) {
            return;
        }

        console.log('-- updateState', data);
        
        if (data.hasOwnProperty("user_card_cnt")) {
            updateCardsHeader(data.user_card_cnt);
            updateCardOpenButtons(data.user_card_cnt);
        }

        if (data.hasOwnProperty("user_progress")) {
            updateCardStacks(data.user_progress);
            updateMainReward(data.user_progress);
        }
    }

    function hideTooltip() {
        elements["tooltipSimple"].style.display = "none";
    }

    function showConfirm(text) {
        elements["modalBlocker"].dataset.state = STATE_OPEN;
        elements["confirmPopup"].dataset.state = STATE_OPEN;
        elements["helpButton"].dataset.state = STATE_CLOSE;

        elements["confirmPopupText"].innerText = text;
    }

    function showError(text) {
        var node = template_error.cloneNode(true);
        
        node.innerHTML = text;
        node.addEventListener("click", onErrorClick);
        node.addEventListener("animationend", onErrorClick);

        elements["errorContainer"].appendChild(node);

        setTimeout(function() {
            node.classList.add("error-animate");
        }, 16);
    }

    function placeTooltip(target) {
        var tooltipRect = elements["tooltipSimple"].getBoundingClientRect();
        var targetRect = target.getBoundingClientRect();

        var relativePosition = getRelativePosition(targetRect);
        var relativeCenter = relativePosition.x + (targetRect.width / 2);

        elements["tooltipSimple"].style.left = relativeCenter - (tooltipRect.width / 2) + "px";
        elements["tooltipSimple"].style.top = relativePosition.y - (tooltipRect.height + 15) + "px";
    }

    function pluralize(count, words) {
        var cases = [2, 0, 1, 1, 1, 2];
        return count + " " + words[ (count % 100 > 4 && count % 100 < 20) ? 2 : cases[ Math.min(count % 10, 5)] ];
    }

    function closeAllModals() {
        elements["helpButton"].dataset.state = STATE_HELP;
        elements["rules"].dataset.state = STATE_CLOSE;
        elements["cardFlipper"].dataset.state = STATE_CLOSE;
        elements["confirmPopup"].dataset.state = STATE_CLOSE;
        elements["modalBlocker"].dataset.state = STATE_CLOSE;
        elements["mainRewardConfirmPopup"].dataset.state = STATE_CLOSE;

        if (waitForUpdate) {
            updateState(update_data);
            
            waitForUpdate = false;
            update_data = null;
        }

        if (waitForConfirm) {
            rowId = -1;
            confirmType = null;
            waitForConfirm = false;
        }
    }

    function getRelativePosition(childRect) {
        var parentRect = elements["main"].getBoundingClientRect();

        return {
            x: childRect.left - parentRect.left,
            y: childRect.top - parentRect.top
        };
    }

    function isNull(val) {
        if (typeof val === "undefined" || val === null) {
            return true;
        }

        return false;
    }

    function DOMElementFromString(str) {
        var tempElement = doc.createElement("div");
        tempElement.innerHTML = str;

        return tempElement.firstElementChild;
    }

    function setupDOM() {
        elements["main"] = doc.getElementById("solitaire_main");
        elements["body"] = doc.getElementById("solitaire_body");
        elements["rules"] = doc.getElementById("solitaire_rules");
        elements["rulesInner"] = elements["rules"].querySelector(".rules-inner");
        elements["cardFlipper"] = doc.getElementById("solitaire_cardFlipper");
        elements["cardFlip"] = elements["cardFlipper"].querySelector(".card-flip");
        elements["cardFlipImage"] = elements["cardFlipper"].querySelector(".card-flip-image");
        elements["modalBlocker"] = doc.getElementById("solitaire_modalBlocker");
        elements["helpButton"] = doc.getElementById("solitaire_helpButton");
        elements["cardsHeader"] = doc.getElementById("solitaire_cardsHeader");
        elements["cardStack"] = doc.getElementById("solitaire_cardStack");
        elements["cardStackButtons"] = doc.getElementById("solitaire_cardStackButtons");
        elements["timerLabel"] = doc.getElementById("solitaire_timerLabel");
        elements["timerValue"] = doc.getElementById("solitaire_timerValue");
        elements["accountButton"] = doc.getElementById("solitaire_accountButton");
        elements["mainReward"] = doc.getElementById("solitaire_mainReward");
        elements["tooltipSimple"] = doc.getElementById("solitaire_tooltipSimple");
        elements["confirmPopup"] = doc.getElementById("solitaire_confirmPopup");
        elements["confirmPopupText"] = elements["confirmPopup"].querySelector(".confirm-popup-text");
        elements["confirmPopupNo"] = elements["confirmPopup"].querySelector("[data-action='no']");
        elements["confirmPopupYes"] = elements["confirmPopup"].querySelector("[data-action='yes']");
        elements["mainRewardHeader"] = elements["mainReward"].querySelector(".main-reward-header");
        elements["mainRewardChest"] = elements["mainReward"].querySelector(".chest");
        elements["mainRewardChestChains"] = elements["mainReward"].querySelector(".chest-chains");
        elements["mainRewardChestLocksArray"] = elements["mainReward"].querySelectorAll(".chest-lock");
        elements["mainRewardConfirmPopup"] = doc.getElementById("solitaire_mainRewardPopup");
        elements["mainRewardConfirmPopupImage"] = elements["mainRewardConfirmPopup"].querySelector(".column-reward-image");
        elements["mainRewardConfirmPopupButton"] = elements["mainRewardConfirmPopup"].querySelector(".rounded-button");
        elements["errorContainer"] = doc.getElementById("solitaire_errorContainer");

        setupExpireTime();
        setupTimer();
        setupCardsBack();
        setupCardOpenButtons();
        setupColumns();

        updateState(solitaire_data);

        elements["rulesInner"].innerHTML = solitaire_data.solitaire.description;

        elements["helpButton"].addEventListener("click", onHelpButtonClick);
        elements["accountButton"].addEventListener("click", onByButtonClick);
        elements["confirmPopupNo"].addEventListener("click", onCondirmNoClick);
        elements["confirmPopupYes"].addEventListener("click", onCondirmYesClick);
    }

    // event handlers ---------------------
    // ------------------------------------
    function onHelpButtonClick(e) {
        if (e.currentTarget.dataset.state === STATE_HELP) {
            e.currentTarget.dataset.state = STATE_CLOSE;
            
            elements["rules"].dataset.state = STATE_OPEN;
            elements["modalBlocker"].dataset.state = STATE_OPEN;
        } else if (e.currentTarget.dataset.state === STATE_CLOSE_MAIN_REWARD) {
            e.currentTarget.dataset.state = STATE_HELP;

            onMainRewardPopupClose(mainRowId);
        } else {
            e.currentTarget.dataset.state = STATE_HELP;

            closeAllModals();
            onCardFlipTransitionEnd();
            updateMainReward();
        }
    }

    function onByButtonClick() {
        // В настоящий момент покупка карт напрямую не используется
        //
        // entry_point_request("solitaire", "take_row_award", { id: solitaire_id, cnt: 1 }, function(data) {
        //     updateCardsHeader(data.user_card_cnt);
        // });

        if (solitaire_data.solitaire.pack_id) {
            entry_point_request("bank", "bank_pack_pay_url", { pack_id: solitaire_data.solitaire.pack_id }, function(data) {
                const status = parseInt(data.status);

                if (status === 100) {
                    const html = $(template_bankIframeContainer.cloneNode(true));
                    const url = data.url;

                    html.find('a').attr('href', url).text(url);
                    html.find('iframe').attr('src', url);

                    if (is_extopen && !/^[\/]/.test(url)) {
                        html.find('.bank-iframe').hide();
                        html.find('.bank-popup-external').show();
                    }

                    showPaymentDialog(html, "Покупка", 640, url);
                } else {
                    showError(data.error);
                }
            });
        } else if (solitaire_data.solitaire.bank_link) {
            _top().frames["main_frame"].frames["main"].location.href = solitaire_data.solitaire.bank_link;

            popupDialogClose();
        } else {
            _top().frames["main_frame"].frames["main"].location.href = "/area_banks.php?&mode=buy";
            
            popupDialogClose();
        }
    }

    function onCardFlipTransitionEnd() {
        elements["helpButton"].dataset.state = STATE_HELP;

        if (lastFlipCard) {
            lastFlipCard.removeEventListener("transitionend", onCardFlipTransitionEnd);
            lastFlipCard.removeEventListener("webkitTransitionEnd", onCardFlipTransitionEnd);

            lastFlipCard = null;
        }

        clearTimeout(modalCloseTimer);
        modalCloseTimer = setTimeout(function() {
            closeAllModals();
        }, 1000);
    }

    function onOpenCardButtonClick(e) {
        if (e.currentTarget.dataset.state === STATE_DISABLED) {
            return;
        }

        var cnt = parseInt(e.currentTarget.dataset.cnt);

        entry_point_request("solitaire", "open_card", { id: solitaire_id, cnt: cnt }, function(data) {
            const status = parseInt(data.status);

            if (status === 100) {
                setupFlipCards(cnt, data.selected_rows);

                setTimeout(function() {
                    elements["cardFlipper"].dataset.state = STATE_OPEN;
                    elements["modalBlocker"].dataset.state = STATE_OPEN;
                    elements["helpButton"].dataset.state = STATE_CLOSE;

                    waitForUpdate = true;
                    update_data = data;
                }, 50);
            } else {
                showError(data.error);
            }
        });
    }

    function onClaimReward(id) {
        rowId = id;
        confirmType = CLAIM_REWARD;
        waitForConfirm = true;

        showConfirm("Вы уверены, что хотите забрать награду?");
    }

    function onClaimCard(id) {
        rowId = id;
        confirmType = CLAIM_CARD;
        waitForConfirm = true;

        showConfirm("Вы уверены, что хотите переместить карту в следующий ряд?");
    }

    function onClaimOver(type, e) {
        elements["tooltipSimple"].style.display = "block";

        if (type === CLAIM_REWARD) {
            elements["tooltipSimple"].querySelector(".tooltip-simple-text").innerHTML = "Забрать награду";
        }

        if (type === CLAIM_CARD) {
            elements["tooltipSimple"].querySelector(".tooltip-simple-text").innerHTML = "Переместить карту в<br />следующий ряд";
        }

        placeTooltip(e.currentTarget);
    }

    function onColumnRewardClick(awards, e) {
        var award = awards[0];

        win.showArtifactInfo(null, award.artikul_id);
    }

    function onCondirmNoClick() {
        closeAllModals();
    }

    function onCondirmYesClick() {
        if (confirmType === CLAIM_REWARD) {
            entry_point_request("solitaire", "take_row_award", { id: solitaire_id, row_id: rowId }, function(data) {
                const status = parseInt(data.status);

                if (status === 100) {
                    updateState(data);
                } else {
                    showError(data.error);
                }
            });
        }

        if (confirmType === CLAIM_CARD) {
            entry_point_request("solitaire", "change_row_card", { id: solitaire_id, row_id: rowId }, function(data) {
                const status = parseInt(data.status);

                if (status === 100) {
                    updateState(data);
                } else {
                    showError(data.error);
                }
            });
        }

        closeAllModals();
    }

    function onChestChainsTransitionEnd(data) {
        var isOneAward = solitaire_data.solitaire.last_row_one_award;
        mainAwardGiven = data.object_awards_give;

        if (isOneAward && mainAwardGiven) {
            return;
        }

        const state = elements["mainRewardChestChains"].dataset.state;

        if (state === STATE_UNLOCKED) {
            elements["modalBlocker"].dataset.state = STATE_OPEN;
            elements["mainRewardConfirmPopup"].dataset.state = STATE_OPEN;
            elements["helpButton"].dataset.state = STATE_CLOSE_MAIN_REWARD;
        }

        mainRowId = data.id;
    }

    function onMainRewardPopupClose() {
        if (mainRowId >= 0) {
            entry_point_request("solitaire", "take_row_award", { id: solitaire_id, row_id: mainRowId }, function(data) {
                const status = parseInt(data.status);

                if (status === 100) {
                    mainAwardGiven = true;

                    updateState(data);
                } else {
                    showError(data.error);
                }
            });
        }

        closeAllModals();
    }

    function onErrorClick(e) {
        e.currentTarget.removeEventListener("click", onErrorClick);
        e.currentTarget.parentNode.removeChild(e.currentTarget);
    }

    // public ========================================================
    // ===============================================================
    return {
        open: function(id) {
            var xhr = new XMLHttpRequest();

            xhr.open("GET", TEMPLATE_PATH + "solitaire.html", true);
            xhr.responseType = "document";

            xhr.onreadystatechange = function() {
                if (this.readyState === 4 && this.status === 200) {
                    var template_main = this.response.getElementById("solitaire_game").innerHTML;

                    template_cardStackButton = DOMElementFromString(this.response.getElementById("solitaire_cardStackButton").innerHTML);
                    template_bodyColumn = DOMElementFromString(this.response.getElementById("solitaire_bodyColumn").innerHTML);
                    template_stackCard = DOMElementFromString(this.response.getElementById("solitaire_stackCard").innerHTML);
                    template_flipCard = DOMElementFromString(this.response.getElementById("solitaire_flipCard").innerHTML);
                    template_bankIframeContainer = DOMElementFromString(this.response.getElementById("solitaire_bankIframeContainer").innerHTML);
                    template_error = DOMElementFromString(this.response.getElementById("solitaire_error").innerHTML);

                    entry_point_request("solitaire", "list", {}, function(data) {
                        const status = parseInt(data.status);
                        solitaire_id = id ? id : 1;

                        if (status === 100) {
                            entry_point_request("solitaire", "get_config", { id: solitaire_id }, function(data) {
                                const status = parseInt(data.status);

                                if (status === 100) {
                                    solitaire_data = data;

                                    popupDialog2(template_main, data.solitaire.title, 736, 752, true, function() {
                                        setupDOM();

                                        win.popupDialogObj.o.beforeClose = function() {
                                            clearInterval(expireTimer);
                                        };
                                    });
                                } else {
                                    popupDialog(data.error, "Пасьянс");
                                }
                            });
                        } else {
                            popupDialog(data.error, "Пасьянс");
                        }
                    });
                }
            };

            xhr.send();
        },

        logConfig: function() {
            console.log('--- Solitaire config', solitaire_data);
        }
    };
})(_top(), _top().document);

